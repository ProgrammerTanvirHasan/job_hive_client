generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id            Int      @id @default(autoincrement())
  name          String?
  email         String   @unique
  password      String
  role          Role     @default(USER)
status UserStatus @default(ACTIVE)
  image         String?

  emailVerified Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt


  jobs              Job[]
  applications      Application[]
  payments          Payment[]
  votes             Vote[]
  comments          Comment[]
  sessions          Session[]
  accounts          Account[]
  
 

  @@map("user")
}




model Job {
  id          Int       @id @default(autoincrement())

  title       String
  description String
  company     String
  location    String
  salary      String?
  category    String

  isPaid      Boolean   @default(false)
  price       Float?

  status      JobStatus @default(PENDING)

  rejectionReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recruiterId Int
  recruiter   User @relation(fields: [recruiterId], references: [id], onDelete: Restrict)

  applications Application[]
  payments     Payment[]
  votes        Vote[]
  comments     Comment[]

  @@index([recruiterId])
  @@index([status])
  @@index([category])
 

}


model Application {
  id          Int               @id @default(autoincrement())
  resume      String
  coverLetter String?
  status      ApplicationStatus @default(PENDING)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId Int
  jobId  Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])  
  @@index([userId])           
  @@index([jobId])         
}


model Payment {
  id        Int           @id @default(autoincrement())
  amount    Float
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  userId Int
  jobId  Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
}



model Vote {
  id   Int      @id @default(autoincrement())
  type VoteType

  userId Int
  jobId  Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
}



model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  jobId  Int
  parentId Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentThread")

  @@index([jobId])
  @@index([userId])
  @@index([parentId])
}



model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}


model Account {
  id         String @id @default(cuid())
  accountId  String
  providerId String

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}



model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}


/* ================= ENUMS ================= */
enum JobStatus {
  PENDING
  APPROVED
  REJECTED
}
enum Role {
  ADMIN
  RECRUITER
  USER
}
enum UserStatus {
  ACTIVE
  BANNED
  INACTIVE
}



enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
}

enum VoteType {
  UP
  DOWN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}