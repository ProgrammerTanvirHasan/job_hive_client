generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  RECRUITER
  USER
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
}

enum VoteType {
  UP
  DOWN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id          Int       @id @default(autoincrement())
  name        String?
  email       String    @unique
  password    String
  role        Role      @default(USER)
  createdAt   DateTime  @default(now())
  jobs        Job[]     @relation("RecruiterJobs")
  applications Application[]
  payments    Payment[]
  votes       Vote[]
  comments    Comment[]
}

model Job {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  company     String
  location    String
  salary      String?
  category    String
  isPaid      Boolean   @default(false)
  price       Float?
  status      JobStatus @default(PENDING)
  createdAt   DateTime  @default(now())

  recruiter   User      @relation("RecruiterJobs", fields: [recruiterId], references: [id])
  recruiterId Int

  applications Application[]
  payments     Payment[]
  votes        Vote[]
  comments     Comment[]
}

model Application {
  id          Int               @id @default(autoincrement())
  resume      String
  coverLetter String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  user        User @relation(fields: [userId], references: [id])
  userId      Int

  job         Job  @relation(fields: [jobId], references: [id])
  jobId       Int
}

model Payment {
  id        Int           @id @default(autoincrement())
  amount    Float
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  user      User @relation(fields: [userId], references: [id])
  userId    Int

  job       Job  @relation(fields: [jobId], references: [id])
  jobId     Int
}

model Vote {
  id      Int      @id @default(autoincrement())
  type    VoteType

  user    User @relation(fields: [userId], references: [id])
  userId  Int

  job     Job  @relation(fields: [jobId], references: [id])
  jobId   Int

  @@unique([userId, jobId]) 
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  createdAt DateTime  @default(now())

  user      User @relation(fields: [userId], references: [id])
  userId    Int

  job       Job  @relation(fields: [jobId], references: [id])
  jobId     Int

  parentId  Int?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}