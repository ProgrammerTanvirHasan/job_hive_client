{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "rootDir": ".",
    // "outDir": "./dist",
    "target": "ES2023",
    "types": ["node", "express"],
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "generated/prisma/**/*"],
  "exclude": ["node_modules"]
}
